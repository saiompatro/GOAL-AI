# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Kaggle (for dataset download)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Hugging Face (optional, only needed for gated models)
HF_TOKEN=

# Streamlit reads SUPABASE_URL / SUPABASE_ANON_KEY directly from the env above.
# On Streamlit Cloud, set those as Secrets. On Render, set as environment variables.
