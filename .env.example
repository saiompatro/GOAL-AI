# Firebase
# For Render, paste the full service-account JSON as one env var.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-firebase-project-id"}

# For local development, you can use a local JSON key file instead.
# Keep that JSON file out of git.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.local.json

# Kaggle (for dataset download)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Hugging Face (optional, only needed for gated models)
HF_TOKEN=

# On Render, set these as environment variables.
